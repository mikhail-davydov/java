# =============================================================================
# Environment Configuration for n8n Stack (Template)
# Version: 2.1 - Simplified (web + webhook merged)
# =============================================================================
# Copy this file to .env and update with your values
# Usage: cp .env.example .env && nano .env

# =============================================================================
# PostgreSQL Configuration
# =============================================================================
POSTGRES_USER=n8n
POSTGRES_PASSWORD=YourSecurePostgresPassword123!
POSTGRES_DB=n8n

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_PASSWORD=YourSecureRedisPassword456!

# =============================================================================
# n8n Configuration - Main Instance
# =============================================================================
N8N_HOST=localhost
N8N_PROTOCOL=http

# Webhook URLs (update for production with real domain)
N8N_EDITOR_BASE_URL=http://localhost:5678
N8N_WEBHOOK_URL=http://localhost:5678

# Authentication (only for web UI)
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=YourSecureN8NPassword789!

# Logging (debug, info, warn, error)
N8N_LOG_LEVEL=info

# Security - restrict file system access
N8N_RESTRICT_FILE_ACCESS_TO=
N8N_ALLOWED_FILESYSTEM_PATHS=

# Timezone
GENERIC_TIMEZONE=Europe/Moscow

# External port
N8N_PORT=5678

# =============================================================================
# Ollama Configuration
# =============================================================================
OLLAMA_PORT=11434

# Модель для автоматической загрузки при старте (оставьте пустым чтобы не загружать)
# Доступные модели: llama2, mistral, codellama, phi3, gemma, neural-chat
OLLAMA_DEFAULT_MODEL=llama2

# =============================================================================
# Ollama Manager - дополнительные модели (через пробел)
# =============================================================================
# OLLAMA_EXTRA_MODELS=mistral codellama

# =============================================================================
# Worker Scaling (advanced)
# =============================================================================
# Number of worker replicas (use: docker-compose up -d --scale n8n-worker=3)
# WORKER_REPLICAS=1

# =============================================================================
# Performance Tuning
# =============================================================================
# PostgreSQL connection pool
# DB_POSTGRESDB_POOL_MAX=20
# DB_POSTGRESDB_POOL_MIN=5

# Redis connection settings
# REDIS_DB=0
# REDIS_TIMEOUT=10000